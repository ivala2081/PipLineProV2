# =====================================================================
# CLIENT ENVIRONMENT VARIABLES (exposed in browser bundle)
# =====================================================================
# IMPORTANT: Only put public keys here. Never put secret API keys!
# All VITE_* variables are bundled into JavaScript and visible to users.
# =====================================================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Service role key — used for admin user creation (god/admin adding members)
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# hCaptcha (bot protection - site key is safe to expose)
# Get a site key from: https://www.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key-here

# =====================================================================
# SERVER-SIDE API KEYS (Supabase Edge Functions only)
# =====================================================================
# These should NEVER be in .env - set them in Supabase Dashboard:
# Dashboard → Edge Functions → Secrets
#
# Required secrets:
# - TATUM_API_KEY (from https://tatum.io)
# - GEMINI_API_KEY (from https://aistudio.google.com/app/apikey)
# - EXCHANGE_RATE_API_KEY (from https://freecurrencyapi.com)
# - RESEND_API_KEY (for email sending)
# - ALLOWED_ORIGINS (comma-separated list of allowed domains)
#
# Example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com
# =====================================================================

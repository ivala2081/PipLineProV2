# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Tatum API (crypto wallet balance & transaction data)
# Get a key from: https://tatum.io
VITE_TATUM_API_KEY=your-tatum-api-key-here

# Exchange Rate API (freecurrencyapi.com - USD/TRY rates)
# Get a key from: https://freecurrencyapi.com
VITE_EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key-here
